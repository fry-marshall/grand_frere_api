NODE_ENV=dev
PORT=3000
ALLOWED_ORIGINS=

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/grand_frere_dev

# Generate with: openssl rand -hex 32
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Storage (optional in dev — Noop implementation used)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Firebase (optional in dev — Noop implementation used)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Mail (optional in dev — Noop implementation used)
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@example.com

# Twilio (optional in dev — Noop implementation used)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
