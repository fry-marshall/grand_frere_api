NODE_ENV=prod
PORT=3000
ALLOWED_ORIGINS=https://yourdomain.com

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Generate with: openssl rand -hex 32
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Storage (required in prod)
DO_SPACES_ENDPOINT=
DO_SPACES_REGION=
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=

# Firebase (required in prod)
# Paste the service account JSON compacted to a single line: cat serviceAccountKey.json | jq -c .
FIREBASE_SERVICE_ACCOUNT=

# Mail (required in prod)
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@yourdomain.com

# Twilio (required in prod)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Paystack (required in prod)
PAYSTACK_SECRET_KEY=

# Seed — only used by npm run seed, not loaded by the app
SUPER_ADMIN_PHONE=
SUPER_ADMIN_PASSWORD=
